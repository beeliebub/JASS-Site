// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  OWNER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
}

// Block-based page builder. Home/Rules/Features/News are migrated
// into this system as `protected` rows (blocks delete + slug change); admins
// can additionally create fully custom pages rendered via app/[slug].
model Page {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  metaDescription String?
  headerContent   String? // JSON; null = no content between the site logo and navigation
  published       Boolean      @default(false)
  protected       Boolean      @default(false)
  theme           String? // one of lib/themes.ts THEME_IDS; null = follow visitor theme
  customThemeId   String? // mutually exclusive with `theme`; see lib/validation/pages.ts
  customTheme     CustomTheme? @relation(fields: [customThemeId], references: [id], onDelete: SetNull)
  blocks          Block[]
  navItems        NavItem[]
  updatedAt       DateTime     @updatedAt
  updatedBy       String?
}

// Admin-authored full ~16-token color sets, selectable anywhere a
// built-in lib/themes.ts theme is today. Field-by-field hex strings (not a
// JSON blob) so each one gets independent Zod validation server-side, same
// reasoning as every other color token in this project. `onDelete: SetNull`
// on Page.customTheme means deleting a theme in use silently reverts those
// pages to following the visitor's own theme -- no dangling reference, no
// blocked delete (confirmed default).
model CustomTheme {
  id                String   @id @default(cuid())
  name              String   @unique
  background        String
  surface           String
  surface2          String
  border            String
  borderStrong      String
  foreground        String
  muted             String
  primary           String
  primaryForeground String
  primaryHover      String
  accent            String
  accentForeground  String
  danger            String
  info              String
  online            String
  offline           String
  // Off by default: a newly-created theme is available to assign to specific
  // pages immediately, but only appears as an option in the visitor-facing
  // footer theme picker once an admin explicitly opts it in from
  // /admin/themes. Doesn't affect a visitor who already has this theme
  // active via localStorage (see lib/custom-themes.ts's getVisibleCustomThemes).
  showInPicker      Boolean  @default(false)
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  pages             Page[]
}

// `data` is JSON-as-string (matches the existing ContentBlock.value
// convention -- no native SQLite JSON type) -- parse/validate at the API
// boundary per `type` with the discriminated union in lib/validation/pages.ts.
// `type: "custom"` is the one exception: its `data` shape isn't known
// statically, so it's validated against `blockDefinition`'s own field
// definitions instead (see lib/validation/block-definitions.ts).
model Block {
  id                String           @id @default(cuid())
  page              Page             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId            String
  order             Int
  type              String
  data              String
  updatedAt         DateTime         @updatedAt
  updatedBy         String?
  ruleSections      RuleSection[]
  features          Feature[]
  posts             Post[]
  blockDefinition   BlockDefinition? @relation("CustomBlockInstances", fields: [blockDefinitionId], references: [id])
  blockDefinitionId String?
}

// Admin-authored block *type*. A definition's `fields` describe the shape of
// `Block.data` for every `Block` row with `type: "custom"` and this
// definition's id as `blockDefinitionId` -- see the dynamic-schema builder in
// lib/validation/block-definitions.ts. `key` is immutable after create (it's
// never actually read back out anywhere yet, only guaranteed unique/stable
// for whenever something needs a durable non-id reference); `name` is the
// only admin-facing label. `renderMode: "fields"` uses one of the fixed
// `layout` template ids; `renderMode: "html"` uses `htmlTemplate` with the
// same fields as placeholders. `layout` remains set in both modes so a
// definition can switch back to field rendering without losing its choice.
model BlockDefinition {
  id               String                 @id @default(cuid())
  key              String                 @unique
  name             String
  description      String?
  layout           String
  renderMode       String                 @default("fields")
  htmlTemplate     String?
  remapThemeColors Boolean                @default(false)
  fields           BlockFieldDefinition[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  createdBy        String?
  blocks           Block[]                @relation("CustomBlockInstances")
}

// One field on a BlockDefinition. `key` is the JSON key this field occupies
// on every Block.data instance of the owning definition; `order` is display
// order in both the field editor and (per-template) instance rendering.
// `config` is JSON-as-string, shaped per `fieldType` (see
// lib/validation/block-definitions.ts) -- for `fieldType: "repeater"`,
// `config.fields` holds the row's own item field defs inline as JSON (not
// more BlockFieldDefinition rows), each restricted to a non-repeater
// fieldType so repeaters never nest more than one level deep.
model BlockFieldDefinition {
  id                String          @id @default(cuid())
  blockDefinition   BlockDefinition @relation(fields: [blockDefinitionId], references: [id], onDelete: Cascade)
  blockDefinitionId String
  key               String
  label             String
  fieldType         String
  order             Int
  required          Boolean         @default(false)
  helpText          String?
  config            String
}

// One level of dropdown nesting only (enforced in lib/validation/pages.ts,
// not just the admin UI): a NavItem whose own parentId is set cannot be used
// as somebody else's parentId.
model NavItem {
  id       String    @id @default(cuid())
  label    String
  href     String?
  page     Page?     @relation(fields: [pageId], references: [id])
  pageId   String?
  order    Int
  parent   NavItem?  @relation("NavItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  children NavItem[] @relation("NavItemChildren")
}

// Singleton, free-form site text keyed by a stable string (hero.name,
// hero.tagline, server.ip, etc.) — anything hardcoded in
// lib/site-config.ts that isn't its own list (rules/features/posts).
model ContentBlock {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model RuleSection {
  id          String @id @default(cuid())
  order       Int
  title       String
  description String
  rules       Rule[]
  block       Block  @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId     String
}

model Rule {
  id          String      @id @default(cuid())
  order       Int
  title       String
  description String
  section     RuleSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId   String
}

model Feature {
  id          String  @id @default(cuid())
  order       Int
  eyebrow     String
  title       String
  description String
  // Key into the icon registry in components/features/icons.tsx (e.g. "tunneller") —
  // JSX can't be stored in the DB, so admins pick from a fixed set of icons.
  icon        String
  accent      Boolean @default(false)
  block       Block   @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId     String
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  tags        Tag[]
  title       String
  excerpt     String
  body        String?
  publishedAt DateTime
  author      String?
  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  blockId     String
}

// Shared across every Post List block on the site (posts themselves are
// owned per-block, but a tag's name/color apply everywhere that name is
// used) -- admin-controlled color lets a tag like "Announcement" carry a
// consistent look wherever it's rendered instead of every tag sharing one
// hardcoded accent color.
model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String // "#rrggbb" hex, validated in lib/validation/content.ts
  posts Post[]
}

// Resource pack hosting. Content-addressed on disk at
// <UPLOADS_DIR>/resource-packs/<sha1>.zip (see lib/uploads.ts) -- this row
// is metadata only, never the file bytes. Exactly one row is `active` at a
// time; re-uploading a known sha1 re-activates its existing row instead of
// duplicating (see POST /api/resource-pack).
model ResourcePack {
  id         String   @id @default(cuid())
  filename   String // sanitized original name, display only -- never used as a storage path
  size       Int // bytes; 256 MiB max fits Int comfortably
  sha1       String   @unique // lowercase hex, 40 chars
  active     Boolean  @default(false)
  uploadedAt DateTime @default(now())
  uploadedBy String? // uploader email, display only
}

// Direct image uploads for the Image block. Content-addressed on
// disk at <UPLOADS_DIR>/images/<sha1>.<ext> (see lib/uploads.ts) -- this row
// is metadata only. Unlike ResourcePack there's no single "active" row: many
// uploaded images are referenced at once, one per Image block. Re-uploading
// identical bytes resolves to the existing row (upsert by sha1).
model UploadedImage {
  id                 String         @id @default(cuid())
  sha1               String         @unique // lowercase hex, 40 chars
  ext                String // derived from validated magic bytes, not client input
  mime               String // one of the 4 allowed values, never freeform
  size               Int
  uploadedAt         DateTime       @default(now())
  uploadedBy         String? // uploader email, display only
  faviconForSettings SiteSettings[] @relation("SiteSettingsFavicon")
  embedForSettings   SiteSettings[] @relation("SiteSettingsEmbed")
}

// Audit trail + single-step undo for every admin mutation across
// the CMS. Entity-agnostic on purpose (one table, not one per entity type) --
// `entityType` is a string, not a Prisma enum, so this model never needs a
// migration when a new auditable entity is added later. `before`/`after` are
// JSON-as-string snapshots of the *logical* row (relations stripped, Block's
// `data` pre-parsed, User's `passwordHash` always excluded -- see
// lib/audit-log.ts), matching the `Block.data` JSON-as-string convention.
model AuditLogEntry {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String // "create" | "update" | "delete"
  before     String? // JSON snapshot, null for create
  after      String? // JSON snapshot, null for delete
  actorEmail String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

// Site-wide editing access, favicon, and link-share/embed defaults. Singleton row
// (fixed id, upsert-on-read via lib/site-settings.ts) rather than the
// generic ContentBlock key-value store, since these fields have a stronger
// shape (validated image references, bounded text) -- same reasoning as
// CustomTheme's field-per-token precedent.
model SiteSettings {
  id               String         @id @default("singleton")
  faviconImageId   String?
  faviconImage     UploadedImage? @relation("SiteSettingsFavicon", fields: [faviconImageId], references: [id], onDelete: SetNull)
  embedImageId     String?
  embedImage       UploadedImage? @relation("SiteSettingsEmbed", fields: [embedImageId], references: [id], onDelete: SetNull)
  embedTitle       String?
  embedDescription String?
  pageTitleSuffix  String?
  editingEnabled   Boolean        @default(true)
  updatedAt        DateTime       @updatedAt
  updatedBy        String?
}
