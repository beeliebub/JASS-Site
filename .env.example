# Copy to .env and fill in real values. Never commit .env.

DATABASE_URL="file:./prisma/dev.db"

# Auth.js session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=""

# Minecraft server used for the live status ping
MC_SERVER_HOST="localhost"
MC_SERVER_PORT="25565"

# Directory for uploaded resource packs. Optional, defaults to
# ./uploads relative to the project root.
# UPLOADS_DIR="./uploads"
